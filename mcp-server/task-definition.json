{
  "family": "als-mcp-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::552960913849:role/als-mcp-exec-role",
  "taskRoleArn": "arn:aws:iam::552960913849:role/als-mcp-task-role",
  "containerDefinitions": [
    {
      "name": "als-mcp",
      "image": "552960913849.dkr.ecr.us-east-1.amazonaws.com/als-mcp:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "ALS_MCP_HOST", "value": "0.0.0.0" },
        { "name": "ALS_MCP_PORT", "value": "8000" }
      ],
      "secrets": [
        {
          "name": "ALS_API_KEY",
          "valueFrom": "arn:aws:ssm:us-east-1:552960913849:parameter/als-mcp/api-key"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/als-mcp",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 15
      }
    }
  ]
}
